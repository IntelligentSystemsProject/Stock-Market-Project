      "source": [
        "## Part 2: Cross-Validation Helper Functions"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 12,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "K1ofHXn9Qj67",
        "outputId": "9ce94d0c-8f20-4533-9d68-9a6a7c818bb8"
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Helper functions defined.\n"
          ]
        }
      ],
      "source": [
        "def make_windows(scaled_arr, ws, ti):\n",
        "    \"\"\"Sliding-window features + target from a scaled numpy array.\"\"\"\n",
        "    X, y = [], []\n",
        "    for i in range(len(scaled_arr) - ws):\n",
        "        X.append(scaled_arr[i:i+ws].flatten())\n",
        "        y.append(scaled_arr[i+ws][ti])\n",
        "    return np.array(X), np.array(y)\n",
        "\n",
        "def inv_scale(preds, sc, ti):\n",
        "    \"\"\"Inverse-scale predictions back to dollar values.\"\"\"\n",
        "    tmp = np.zeros((len(preds), sc.n_features_in_))\n",
        "    tmp[:, ti] = preds\n",
        "    return sc.inverse_transform(tmp)[:, ti]\n",
        "\n",
        "print(\"Helper functions defined.\")\n"
      ]
    },
